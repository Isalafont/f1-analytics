<%# app/views/drivers/index.html.erb — Issue #44 dark theme — Bender 🤖 %>
<% content_for :title, "Drivers — F1 Analytics" %>

<div class="w-full">

  <%# ── Section header ──────────────────────────────────────────── %>
  <div class="flex items-center gap-3 mb-8">
    <h1 class="text-2xl font-bold text-f1-text-primary" style="font-family: 'Barlow', sans-serif;">
      🏎️ Driver Standings
      <span class="text-f1-text-muted text-base font-normal ml-2">Season <%= @drivers.first&.season || Date.current.year %></span>
    </h1>
    <div class="flex-1 h-px bg-f1-red opacity-60"></div>
  </div>

  <%# ── Metric cards ─────────────────────────────────────────────── %>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-f1-bg-surface rounded-card border border-f1-border p-5">
      <p class="text-label text-f1-text-secondary uppercase tracking-widest mb-2">Drivers</p>
      <p class="text-metric-lg font-data text-f1-teal"><%= @drivers.size %></p>
    </div>
    <div class="bg-f1-bg-surface rounded-card border border-f1-border p-5">
      <p class="text-label text-f1-text-secondary uppercase tracking-widest mb-2">Teams</p>
      <p class="text-metric-lg font-data text-f1-teal"><%= @drivers.map(&:team_id).uniq.length %></p>
    </div>
    <% leader = @drivers.max_by(&:total_points) %>
    <div class="bg-f1-bg-surface rounded-card border border-f1-border p-5">
      <p class="text-label text-f1-text-secondary uppercase tracking-widest mb-2">Leader</p>
      <p class="text-sm font-semibold text-f1-text-primary truncate"><%= leader&.last_name || "—" %></p>
    </div>
    <div class="bg-f1-bg-surface rounded-card border border-f1-border p-5">
      <p class="text-label text-f1-text-secondary uppercase tracking-widest mb-2">Leader Pts</p>
      <p class="text-metric-lg font-data text-f1-gold"><%= leader&.total_points || "—" %></p>
    </div>
  </div>

  <%# ── Standings table ─────────────────────────────────────────── %>
  <div class="bg-f1-bg-surface rounded-card border border-f1-border shadow-card overflow-hidden">
    <table class="w-full">
      <thead>
        <tr class="bg-f1-red">
          <th class="px-4 py-3 text-left text-label text-white uppercase tracking-wider">Pos</th>
          <th class="px-4 py-3 text-left text-label text-white uppercase tracking-wider">Driver</th>
          <th class="px-4 py-3 text-left text-label text-white uppercase tracking-wider hidden sm:table-cell">Team</th>
          <th class="px-4 py-3 text-right text-label text-white uppercase tracking-wider hidden md:table-cell">Races</th>
          <th class="px-4 py-3 text-right text-label text-white uppercase tracking-wider">Points</th>
        </tr>
      </thead>
      <tbody>
        <%
          sorted_drivers = @drivers.sort_by { |d| -d.total_points }
        %>
        <% sorted_drivers.each_with_index do |driver, index| %>
          <% pos = index + 1 %>
          <tr class="border-b border-f1-border hover:bg-f1-bg-elevated transition-colors duration-150">
            <td class="px-4 py-3 font-data font-bold">
              <% case pos %>
              <% when 1 %>
                <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-f1-gold text-f1-text-inverse text-sm font-bold">1</span>
              <% when 2 %>
                <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-f1-silver text-f1-text-inverse text-sm font-bold">2</span>
              <% when 3 %>
                <%# Bronze: indicateur graphique ≥ 18px bold uniquement (WCAG 3.8:1 AA large) %>
                <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-f1-bronze text-f1-text-inverse text-sm font-bold">3</span>
              <% else %>
                <span class="text-f1-text-secondary font-data font-bold"><%= pos %></span>
              <% end %>
            </td>
            <td class="px-4 py-3">
              <%= link_to driver_path(driver), class: "group flex items-center gap-2 focus-visible:ring-2 focus-visible:ring-f1-teal focus-visible:outline-none" do %>
                <span class="text-f1-text-muted font-data text-xs">#<%= driver.number %></span>
                <span class="text-f1-text-primary group-hover:text-f1-red transition-colors duration-150 font-medium">
                  <%= driver.full_name %>
                </span>
              <% end %>
            </td>
            <td class="px-4 py-3 hidden sm:table-cell">
              <span class="inline-block px-2 py-0.5 rounded text-xs font-medium text-f1-text-inverse"
                    style="background-color: var(--f1-team-<%= driver.team.tailwind_key %>)">
                <%= driver.team.name %>
              </span>
            </td>
            <td class="px-4 py-3 text-f1-text-secondary font-data text-right hidden md:table-cell">
              <%= driver.results.size %>
            </td>
            <td class="px-4 py-3 font-bold font-data text-right <%= pos == 1 ? 'text-f1-gold' : 'text-f1-teal' %>">
              <%= driver.total_points %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

</div>
