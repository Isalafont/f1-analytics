<!-- app/views/dashboard/index.html.erb -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>F1 Analytics - <%= @season %> Season</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      background: #1a1a1a;
      color: #fff;
      padding: 20px;
    }
    .container { max-width: 1400px; margin: 0 auto; }
    h1 { font-size: 2.5rem; margin-bottom: 10px; color: #e10600; }
    h2 { font-size: 1.8rem; margin: 30px 0 15px; border-bottom: 2px solid #e10600; padding-bottom: 10px; }
    h3 { font-size: 1.3rem; margin: 20px 0 10px; }
    
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 20px;
      margin-bottom: 30px;
    }
    
    .card {
      background: #2a2a2a;
      border-radius: 8px;
      padding: 20px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.3);
    }
    
    table {
      width: 100%;
      border-collapse: collapse;
      background: #2a2a2a;
      border-radius: 8px;
      overflow: hidden;
    }
    
    th, td {
      padding: 12px 15px;
      text-align: left;
      border-bottom: 1px solid #3a3a3a;
    }
    
    th {
      background: #e10600;
      font-weight: 600;
      text-transform: uppercase;
      font-size: 0.85rem;
    }
    
    tr:hover { background: #333; }
    
    .position {
      font-weight: bold;
      font-size: 1.1rem;
      color: #e10600;
      width: 50px;
    }
    
    .points {
      font-weight: bold;
      color: #27f4d2;
    }
    
    .metric-value {
      font-size: 2rem;
      font-weight: bold;
      color: #27f4d2;
      margin: 10px 0;
    }
    
    .metric-label {
      font-size: 0.9rem;
      color: #888;
      text-transform: uppercase;
    }
    
    .upcoming-race {
      background: linear-gradient(135deg, #e10600, #ff4500);
      color: white;
      padding: 15px;
      border-radius: 8px;
      margin-bottom: 10px;
    }
    
    .race-date {
      font-size: 0.9rem;
      opacity: 0.9;
      margin-top: 5px;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>🏎️ F1 Analytics <%= @season %></h1>
    <p style="color: #888; margin-bottom: 30px;">Performance tracking & metrics dashboard</p>

    <!-- Upcoming Races -->
    <% if @upcoming_races.any? %>
      <h2>🚦 Upcoming Races</h2>
      <div class="grid">
        <% @upcoming_races.each do |race| %>
          <div class="upcoming-race">
            <h3><%= race.name %></h3>
            <div class="race-date">
              <%= race.circuit %> • <%= race.country %><br>
              Round <%= race.round %> • <%= race.date.strftime('%B %d, %Y') %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Quick Stats -->
    <h2>📊 Season Overview</h2>
    <div class="grid">
      <div class="card">
        <div class="metric-label">Total Races</div>
        <div class="metric-value"><%= Race.for_season(@season).count %></div>
      </div>
      <div class="card">
        <div class="metric-label">Completed</div>
        <div class="metric-value"><%= Race.for_season(@season).completed.count %></div>
      </div>
      <div class="card">
        <div class="metric-label">Active Drivers</div>
        <div class="metric-value"><%= @drivers.size %></div>
      </div>
      <div class="card">
        <div class="metric-label">Teams</div>
        <div class="metric-value"><%= @teams.count %></div>
      </div>
    </div>

    <!-- Driver Standings -->
    <h2>🏆 Driver Standings</h2>
    <table>
      <thead>
        <tr>
          <th>Pos</th>
          <th>Driver</th>
          <th>Team</th>
          <th class="points">Points</th>
        </tr>
      </thead>
      <tbody>
        <% @drivers.each_with_index do |driver, index| %>
          <tr>
            <td class="position"><%= index + 1 %></td>
            <td><%= driver.display_name %></td>
            <td><%= driver.team.name %></td>
            <td class="points"><%= driver.total_points %></td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <!-- Top Performers -->
    <% if @top_performers.any? %>
      <h2>⭐ Top Performers (Performance Index)</h2>
      <table>
        <thead>
          <tr>
            <th>Rank</th>
            <th>Driver</th>
            <th>Performance Index</th>
            <th>Consistency</th>
            <th>Recent Form</th>
          </tr>
        </thead>
        <tbody>
          <% @top_performers.each_with_index do |driver, index| %>
            <% metric = driver.metrics.season_aggregates.first %>
            <tr>
              <td class="position"><%= index + 1 %></td>
              <td><%= driver.display_name %></td>
              <td class="points"><%= metric&.performance_index&.round(1) || 'N/A' %></td>
              <td><%= metric&.consistency_score&.round(1) || 'N/A' %></td>
              <td><%= metric&.recent_form&.round(1) || 'N/A' %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>

    <!-- Recent Races -->
    <% if @recent_races.any? %>
      <h2>🏁 Recent Races</h2>
      <div class="grid">
        <% @recent_races.each do |race| %>
          <div class="card">
            <h3><%= race.name %></h3>
            <p style="color: #888; margin-bottom: 10px;">
              Round <%= race.round %> • <%= race.date.strftime('%b %d') %>
            </p>
            <% if race.winner %>
              <p><strong>Winner:</strong> <%= race.winner.display_name %></p>
              <p><strong>Pole:</strong> <%= race.pole_sitter&.display_name || 'N/A' %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</body>
</html>
